    "# Outlier Detection — IQR Rule\n",
    "\n",
    "num_cols = ['impressions', 'clicks', 'CTR', \n",
    "            'CPC', 'ad_spend', 'conversions']\n",
    "\n",
    "def iqr_outliers(s):\n",
    "    q1, q3 = s.quantile([0.25, 0.75])\n",
    "    iqr = q3 - q1\n",
    "    return s[(s < q1 - 1.5*iqr) | (s > q3 + 1.5*iqr)]\n",
    "\n",
    "print(\"=== IQR Outlier Detection (training set) ===\\n\")\n",
    "print(f\"  {'Feature':<15} {'IQR Outliers':>12} {'Pct%':>8} {'3std Outliers':>14} {'Severity'}\")\n",

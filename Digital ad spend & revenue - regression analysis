    "print(f\"\\n=== Duplicate Rows: {df.duplicated().sum()} ===\")\n",
    "\n",
    "# 4. Convert date to datetime and extract time features\n",
    "df['date'] = pd.to_datetime(df['date'])\n",
    "df['month'] = df['date'].dt.month\n",
    "df['quarter'] = df['date'].dt.quarter\n",
    "print(\"\\n✓ Date converted — month and quarter extracted\")\n",
    "\n",
    "# 5. Outlier check on key continuous columns\n",
    "print(\"\\n=== Outlier Check (beyond 3 std devs) ===\")\n",
    "cols = ['ad_spend', 'clicks', 'impressions', 'conversions', 'revenue', 'ROAS']\n",
    "for col in cols:\n",
    "    mean, std = df[col].mean(), df[col].std()\n",
    "    outliers = df[(df[col] < mean - 3*std) | (df[col] > mean + 3*std)]\n",
    "    print(f\"  {col}: {len(outliers)} outliers\")\n",
    "\n",
    "# 6. Summary statistics on key columns\n",
    "print(\"\\n=== Summary Statistics ===\")\n",

    "# Intelligent Binning and Discretization\n",
    "# Demonstration only — not used in OLS model\n",
    "\n",
    "from sklearn.preprocessing import KBinsDiscretizer\n",
    "\n",
    "# Method 1: Equal-width binning on ad_spend\n",
    "print(\"=== Method 1: Equal-Width Binning — ad_spend ===\\n\")\n",
    "ad_spend_bins = pd.cut(\n",
    "    train_raw['ad_spend'],\n",
    "    bins=5,\n",
    "    labels=['Very Low', 'Low', 'Medium', 'High', 'Very High']\n",
    ")\n",
    "print(ad_spend_bins.value_counts().sort_index())\n",
    "print(f\"\\nNote: unequal counts — expected for skewed ad_spend\")\n",
    "\n",
    "# Method 2: Equal-frequency (quantile) binning\n",
    "print(\"\\n=== Method 2: Quantile Binning — ad_spend ===\\n\")\n",
    "ad_spend_quantile = pd.qcut(\n",
    "    train_raw['ad_spend'],\n",
    "    q=5,\n",
    "    labels=['Q1 Budget', 'Q2 Budget', 'Q3 Budget', \n",
    "            'Q4 Budget', 'Q5 Budget']\n",
    ")\n",
    "print(ad_spend_quantile.value_counts().sort_index())\n",
    "print(f\"\\nNote: equal counts — better for skewed data\")\n",
    "\n",
    "# Method 3: Domain-based binning on conversions\n",
    "print(\"\\n=== Method 3: Domain-Based Binning — conversions ===\\n\")\n",
    "\n",
    "def conversion_category(conv):\n",
    "    if conv < 50:\n",
    "        return 'Low performer'\n",
    "    elif conv < 200:\n",
    "        return 'Mid performer'\n",
    "    elif conv < 500:\n",
    "        return 'High performer'\n",
    "    else:\n",
    "        return 'Top performer'\n",
    "\n",
    "train_raw['conversion_tier'] = train_raw['conversions'].apply(\n",
    "    conversion_category)\n",
    "tier_counts = train_raw['conversion_tier'].value_counts()\n",
    "print(tier_counts)\n",
    "\n",
    "# Revenue by conversion tier\n",
    "tier_revenue = train_raw.groupby('conversion_tier')['revenue'].mean().round(0)\n",
    "print(\"\\nAverage revenue by conversion tier:\")\n",
    "print(tier_revenue.sort_values(ascending=False))\n",
    "\n",
    "# Method 4: KBinsDiscretizer on conversions\n",
    "print(\"\\n=== Method 4: KBinsDiscretizer — conversions ===\\n\")\n",
    "\n",
    "disc_uniform = KBinsDiscretizer(\n",
    "    n_bins=4, encode='ordinal', strategy='uniform')\n",
    "disc_quantile = KBinsDiscretizer(\n",
    "    n_bins=4, encode='ordinal', strategy='quantile')\n",
    "\n",
    "conv_uniform = disc_uniform.fit_transform(\n",
    "    train_raw[['conversions']])\n",

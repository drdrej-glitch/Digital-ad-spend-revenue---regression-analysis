    "# ── Ridge Regression — Experiment 2 ──────────────────\n",
    "\n",
    "from sklearn.linear_model import Ridge, RidgeCV\n",
    "from sklearn.metrics import r2_score, mean_squared_error\n",
    "import numpy as np\n",
    "\n",
    "# ── Prepare data ──────────────────────────────────────\n",
    "# Use same scaled features as OLS but without statsmodels constant\n",
    "X_tr = X_train_ols.values  # already scaled, month dropped\n",
    "X_te = X_test_ols.values\n",
    "y_tr = y_train_log.values\n",
    "y_te = y_test_log.values\n",
    "\n",
    "# ── Step 1: Find best alpha via cross-validation ──────\n",
    "alphas = [0.001, 0.01, 0.1, 1, 10, 50, 100, 500, 1000]\n",
    "\n",
    "ridge_cv = RidgeCV(alphas=alphas, cv=5, scoring='r2')\n",
    "ridge_cv.fit(X_tr, y_tr)\n",
    "\n",
    "print(\"=== Ridge Alpha Selection (5-fold CV) ===\\n\")\n",
    "print(f\"  Alphas tested:  {alphas}\")\n",
    "print(f\"  Best alpha:     {ridge_cv.alpha_}\")\n",
    "print(f\"  CV R² (best):   {ridge_cv.best_score_:.4f}\")\n",
    "\n",
    "# ── Step 2: Fit Ridge with best alpha ─────────────────\n",
    "ridge = Ridge(alpha=ridge_cv.alpha_)\n",
    "ridge.fit(X_tr, y_tr)\n",
    "\n",
    "# ── Step 3: Evaluate ──────────────────────────────────\n",
    "y_pred_train_ridge = ridge.predict(X_tr)\n",
    "y_pred_test_ridge  = ridge.predict(X_te)\n",
    "\n",
    "r2_train_ridge = r2_score(y_tr, y_pred_train_ridge)\n",
    "r2_test_ridge  = r2_score(y_te, y_pred_test_ridge)\n",
    "rmse_test_ridge = np.sqrt(mean_squared_error(y_te, y_pred_test_ridge))\n",
    "mae_test_ridge  = np.mean(np.abs(y_te - y_pred_test_ridge))\n",
    "rmse_raw_ridge  = np.sqrt(mean_squared_error(\n",
    "    np.expm1(y_te), np.expm1(y_pred_test_ridge)))\n",
    "\n",
    "print(f\"\\n=== Ridge Results (alpha={ridge_cv.alpha_}) ===\\n\")\n",
    "print(f\"  Training R²:    {r2_train_ridge:.4f}\")\n",
    "print(f\"  Test R² (log):  {r2_test_ridge:.4f}\")\n",
    "print(f\"  Train-test gap: {r2_train_ridge - r2_test_ridge:.4f}\")\n",
    "print(f\"  RMSE (log):     {rmse_test_ridge:.4f}\")\n",
    "print(f\"  RMSE (raw $):   ${rmse_raw_ridge:,.0f}\")\n",
    "print(f\"  MAE (log):      {mae_test_ridge:.4f}\")\n",
    "\n",
    "# ── Step 4: Compare OLS vs Ridge ─────────────────────\n",
    "print(f\"\\n=== OLS vs Ridge Comparison ===\\n\")\n",

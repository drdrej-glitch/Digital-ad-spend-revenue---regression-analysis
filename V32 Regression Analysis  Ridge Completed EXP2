    "# ── Automated Feature Selection ───────────────────────\n",
    "\n",
    "from sklearn.feature_selection import SelectKBest, f_regression, RFE\n",
    "from sklearn.ensemble import RandomForestRegressor\n",
    "from sklearn.linear_model import LinearRegression\n",
    "\n",
    "y = y_train.squeeze()\n",
    "\n",
    "# ── Method 1: SelectKBest (F-score) ───────────────────\n",
    "print(\"=== Method 1: SelectKBest — F-Score Ranking ===\\n\")\n",
    "\n",
    "selector = SelectKBest(score_func=f_regression, k=10)\n",
    "selector.fit(X_train_scaled, y)\n",
    "\n",
    "selectkbest_results = pd.DataFrame({\n",
    "    'Feature': X_train_scaled.columns,\n",
    "    'F_Score': selector.scores_,\n",
    "    'P_Value': selector.pvalues_,\n",
    "    'Selected': selector.get_support()\n",
    "}).sort_values('F_Score', ascending=False)\n",
    "\n",
    "print(selectkbest_results.round(3).to_string(index=False))\n",
    "\n",
    "top10_selectkbest = selectkbest_results[\n",
    "    selectkbest_results['Selected']]['Feature'].tolist()\n",
    "print(f\"\\nTop 10 features selected by SelectKBest:\")\n",
    "for i, f in enumerate(top10_selectkbest, 1):\n",
    "    print(f\"  {i:2}. {f}\")\n",
    "\n",
    "# ── Method 2: Random Forest Importance ────────────────\n",
    "print(\"\\n=== Method 2: Random Forest Feature Importance ===\\n\")\n",
    "\n",
    "rf = RandomForestRegressor(\n",
    "    n_estimators=100, random_state=42, n_jobs=-1)\n",
    "rf.fit(X_train_scaled, y)\n",
    "\n",
    "rf_importance = pd.DataFrame({\n",
    "    'Feature': X_train_scaled.columns,\n",
    "    'Importance': rf.feature_importances_\n",
    "}).sort_values('Importance', ascending=False)\n",
    "\n",
    "print(rf_importance.round(4).to_string(index=False))\n",
    "\n",
    "top10_rf = rf_importance.head(10)['Feature'].tolist()\n",
    "print(f\"\\nTop 10 features by Random Forest importance:\")\n",
    "for i, f in enumerate(top10_rf, 1):\n",
    "    print(f\"  {i:2}. {f}\")\n",
    "\n",
    "# ── Method 3: RFE ─────────────────────────────────────\n",
    "print(\"\\n=== Method 3: Recursive Feature Elimination (RFE) ===\\n\")\n",
    "\n",
    "rfe = RFE(estimator=LinearRegression(), \n",
    "          n_features_to_select=10)\n",
    "rfe.fit(X_train_scaled, y)\n",
    "\n",
    "rfe_results = pd.DataFrame({\n",
    "    'Feature': X_train_scaled.columns,\n",
    "    'Selected': rfe.support_,\n",
    "    'Ranking': rfe.ranking_\n",
    "}).sort_values('Ranking')\n",
    "\n",
    "print(rfe_results.to_string(index=False))\n",
    "\n",
    "top10_rfe = rfe_results[\n",
    "    rfe_results['Selected']]['Feature'].tolist()\n",
    "\n",
    "# ── Comparison across all three methods ───────────────\n",
    "print(\"\\n=== Feature Selection Comparison ===\\n\")\n",
    "print(f\"{'Feature':<40} {'SelectKBest':>12} {'RandomForest':>13} {'RFE':>5}\")\n",
    "print(\"-\" * 73)\n",
    "\n",
    "for feature in X_train_scaled.columns:\n",

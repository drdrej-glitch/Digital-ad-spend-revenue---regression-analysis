    "\n",
    "# ── Interaction 2: spend efficiency ───────────────────\n",
    "train_interact['spend_efficiency'] = (\n",
    "    train_interact['conversions'] / train_interact['ad_spend'])\n",
    "\n",
    "corr2 = train_interact['spend_efficiency'].corr(\n",

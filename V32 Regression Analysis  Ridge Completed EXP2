    "axes[0].set_title(f'OLS Residuals\\nTest R²={ols_test:.3f}')\n",
    "axes[0].set_xlabel('Predicted log(Revenue)')\n",
    "axes[0].set_ylabel('Residuals')\n",
    "\n",
    "axes[1].scatter(y_pred_test_ridge, ridge_resid, alpha=0.3,\n",
    "                color='teal', s=15)\n",
    "axes[1].axhline(0, color='red', linestyle='--')\n",
    "axes[1].set_title(f'Ridge Residuals (alpha={ridge_cv.alpha_})\\nTest R²={r2_test_ridge:.3f}')\n",
    "axes[1].set_xlabel('Predicted log(Revenue)')\n",
    "axes[1].set_ylabel('Residuals')\n",

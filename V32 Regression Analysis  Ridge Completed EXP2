    "\n",
    "ols_train  = 0.6384\n",
    "ols_test   = 0.5972\n",
    "ols_gap    = 0.0412\n",
    "ols_rmse   = 37548\n",
    "\n",
    "metrics = [\n",
    "    (\"Training R²\",    ols_train,  r2_train_ridge),\n",
    "    (\"Test R² (log)\",  ols_test,   r2_test_ridge),\n",
    "    (\"Train-test gap\", ols_gap,    r2_train_ridge - r2_test_ridge),\n",
    "    (\"RMSE raw ($)\",   ols_rmse,   rmse_raw_ridge),\n",
    "]\n",
    "\n",
    "for name, ols_val, ridge_val in metrics:\n",
    "    if name == \"RMSE raw ($)\":\n",
    "        change = ridge_val - ols_val\n",
    "        direction = \"better\" if change < 0 else \"worse\"\n",
    "        print(f\"  {name:<25} ${ols_val:>10,.0f} ${ridge_val:>10,.0f}  {direction}\")\n",
    "    elif name == \"Train-test gap\":\n",
    "        change = ridge_val - ols_val\n",
    "        direction = \"better\" if change < 0 else \"worse\"\n",
    "        print(f\"  {name:<25} {ols_val:>12.4f} {ridge_val:>12.4f}  {direction}\")\n",
    "    else:\n",
    "        change = ridge_val - ols_val\n",
    "        direction = \"better\" if change > 0 else \"worse\"\n",
    "        print(f\"  {name:<25} {ols_val:>12.4f} {ridge_val:>12.4f}  {direction}\")\n",
    "\n",
    "# ── Step 5: Coefficient shrinkage comparison ──────────\n",
    "print(f\"\\n=== Coefficient Shrinkage: OLS vs Ridge ===\\n\")\n",
    "print(f\"  {'Feature':<30} {'OLS coef':>10} {'Ridge coef':>11} {'Shrinkage':>10}\")\n",
    "print(\"  \" + \"-\" * 65)\n",
    "\n",
    "ols_coefs = model.params[1:]  # exclude const\n",
    "ridge_coefs = ridge.coef_\n",
    "\n",
    "for i, feat in enumerate(X_train_ols.columns):\n",
    "    ols_c = ols_coefs.iloc[i] if i < len(ols_coefs) else 0\n",
    "    rid_c = ridge_coefs[i]\n",
    "    shrink = abs(ols_c) - abs(rid_c)\n",
    "    print(f\"  {feat:<30} {ols_c:>10.4f} {rid_c:>11.4f} {shrink:>10.4f}\")\n",
    "\n",
